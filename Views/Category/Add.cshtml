@{
    ViewData["Title"] = "Category - Add";
}
@model AddCategoryViewModel;
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-plus-circle"></i> Add New Category
                    </h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="Add" asp-controller="Category">

                        <div class="form-group mb-3">
                            <label class="form-label">
                                <i class="fas fa-tag"></i> Category Name *
                            </label>
                            <input asp-for="Name" class="form-control" placeholder="E.g.: Food, Transportation, Entertainment" />
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">
                                <i class="fas fa-exchange-alt"></i> Category Type *
                            </label>
                            <select class="form-select" asp-for="TransactionType" required>
                                <option value="">Select...</option>
                                <option value="1">Income</option>
                                <option value="2">Expense</option>
                            </select>
                        </div>
@* 
                        <div class="form-group mb-3">
                            <label class="form-label">
                                <i class="fas fa-palette"></i> Color
                            </label>
                            <div class="row">
                                <div class="col-6">
                                    <input name="ColorPicker" type="color" class="form-control form-control-color" 
                                           value="#007bff" title="Select category color">
                                </div>
                                <div class="col-6">
                                    <input name="Color" type="text" class="form-control" 
                                           placeholder="#007bff" maxlength="7">
                                </div>
                            </div>
                            <small class="form-text text-muted">Color to be used in charts and reports</small>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">
                                <i class="fas fa-icons"></i> Icon
                            </label>
                            <select name="Icon" class="form-select">
                                <option value="">Select an icon...</option>
                                <option value="fas fa-shopping-cart">🛒 Shopping</option>
                                <option value="fas fa-car">🚗 Transportation</option>
                                <option value="fas fa-home">🏠 Home</option>
                                <option value="fas fa-utensils">🍽️ Food</option>
                                <option value="fas fa-gamepad">🎮 Entertainment</option>
                                <option value="fas fa-graduation-cap">🎓 Education</option>
                                <option value="fas fa-heartbeat">❤️ Health</option>
                                <option value="fas fa-tshirt">👕 Clothing</option>
                                <option value="fas fa-money-bill-wave">💰 Income</option>
                                <option value="fas fa-piggy-bank">🐷 Savings</option>
                            </select>
                        </div> *@

                        @* <div class="form-check mb-3">
                            <input name="IsActive" class="form-check-input" type="checkbox" checked>
                            <label class="form-check-label">
                                Active category
                            </label>
                            <small class="form-text text-muted d-block">
                                Inactive categories are not visible when adding transactions
                            </small>
                        </div> *@

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="#" class="btn btn-secondary me-md-2">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Add Category
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control-color {
        width: 100%;
        height: 38px;
    }
    
    .category-color-box {
        min-width: 20px;
        min-height: 20px;
    }
    
    .card {
        border: none;
        border-radius: 10px;
    }
    
    .card-header {
        border-radius: 10px 10px 0 0 !important;
    }
    
    .form-control, .form-select {
        border-radius: 8px;
    }
    
    .btn {
        border-radius: 8px;
    }
</style>