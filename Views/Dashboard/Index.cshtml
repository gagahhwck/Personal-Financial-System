@{
    ViewData["Title"] = "Dashboard";
}
@model TransactionIndexViewModel;
<!-- Dashboard Home -->
<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h2 class="mb-1">Hello, @(User.Identity?.Name ?? "Guest")! 👋</h2>
                <p class="text-white-50 mb-0">Here is a summary of your financial status</p>
            </div>
            <div>
                <span class="badge bg-light text-dark fs-6">@DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-4" id="summary-cards">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="summary-card income">
            <i class="fas fa-arrow-up summary-icon"></i>
            <div class="summary-amount" id="total-income">@Model.TotalIncome</div>
            <div class="summary-label">Total Income</div>
            <small class="opacity-75">This month: <span id="monthly-income">@Model.MonthlyIncome</span></small>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-3">
        <div class="summary-card expense">
            <i class="fas fa-arrow-down summary-icon"></i>
            <div class="summary-amount" id="total-expense">@Model.TotalExpense</div>
            <div class="summary-label">Total Expense</div>
            <small class="opacity-75">This month: <span id="monthly-expense">@Model.MonthlyExpense</span></small>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-3">
        <div class="summary-card balance" id="balance-card">
            <i class="fas fa-balance-scale summary-icon"></i>
            <div class="summary-amount" id="net-balance">@Model.Balance</div>
            <div class="summary-label">Net Balance</div>
            <small class="opacity-75">This month: <span id="monthly-balance">@Model.MonthlyBalance</span></small>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 mb-3">
        <div class="summary-card">
            <i class="fas fa-chart-line summary-icon"></i>
            <div class="summary-amount" id="total-transactions">@Model.Transactions.Count</div>
            <div class="summary-label">Transaction Count</div>
            <small class="opacity-75">This month: <span id="monthly-transactions">@Model.MonthlyTransactionCount</span></small>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-bolt me-2"></i>
                    Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <!-- Expense Buttons -->
                    <div class="col-md-2 col-4">
                        <button class="quick-action" onclick="quickAdd('expense', 'installment', 'Installment')">
                            <i class="fas fa-car quick-action-icon text-danger"></i>
                            <span class="quick-action-label">Installment</span>
                        </button>
                    </div>
                    <div class="col-md-2 col-4">
                        <button class="quick-action" onclick="quickAdd('expense', 'fuel', 'Fuel')">
                            <i class="fas fa-gas-pump quick-action-icon text-warning"></i>
                            <span class="quick-action-label">Fuel</span>
                        </button>
                    </div>
                    <div class="col-md-2 col-4">
                        <button class="quick-action" onclick="quickAdd('expense', 'service', 'Service')">
                            <i class="fas fa-wrench quick-action-icon text-info"></i>
                            <span class="quick-action-label">Service</span>
                        </button>
                    </div>
                    <div class="col-md-2 col-4">
                        <button class="quick-action" onclick="quickAdd('expense', 'insurance', 'Insurance')">
                            <i class="fas fa-shield-alt quick-action-icon text-secondary"></i>
                            <span class="quick-action-label">Insurance</span>
                        </button>
                    </div>
                    <div class="col-md-2 col-4">
                        <button class="quick-action" onclick="quickAdd('expense', 'parking', 'Parking')">
                            <i class="fas fa-parking quick-action-icon text-success"></i>
                            <span class="quick-action-label">Parking</span>
                        </button>
                    </div>
                    <div class="col-md-2 col-4">
                        <button class="quick-action" onclick="quickAdd('expense', 'accessories', 'Accessories')">
                            <i class="fas fa-tools quick-action-icon text-muted"></i>
                            <span class="quick-action-label">Accessories</span>
                        </button>
                    </div>
                </div>

                <!-- Income Button -->
                <div class="row mt-3">
                    <div class="col-12">
                        <button class="btn btn-success btn-lg w-100" onclick="quickAdd('income', 'salary', 'Income')">
                            <i class="fas fa-plus me-2"></i>
                            Add Income
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Transactions and Today's Summary -->
<div class="row">
    <!-- Recent Transactions -->
    <div class="col-lg-8 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-history me-2"></i>
                    Recent Transactions
                </h5>
                <a href="/Transaction" class="btn btn-outline-primary btn-sm">
                    View All
                </a>
            </div>
            <div class="card-body">
                <div id="recent-transactions">
                    <!-- To be filled with AJAX -->
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Today's Summary -->
    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-calendar-day me-2"></i>
                    Today's Summary
                </h5>
            </div>
            <div class="card-body text-center">
                <div class="mb-3">
                    <h3 class="text-primary mb-1" id="today-balance">$0.00</h3>
                    <small class="text-muted">Amount you can spend today</small>
                </div>

                <div class="row text-center">
                    <div class="col-6">
                        <div class="border-end">
                            <div class="text-success fw-bold" id="today-income">+$0.00</div>
                            <small class="text-muted">Today's Income</small>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-danger fw-bold" id="today-expense">-$0.00</div>
                        <small class="text-muted">Today's Expense</small>
                    </div>
                </div>

                <hr>

                <div class="d-grid gap-2">
                    <a href="/Transaction/Add" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>
                        Add Detailed Transaction
                    </a>
                    <button class="btn btn-outline-info" onclick="refreshDashboard()">
                        <i class="fas fa-sync-alt me-2"></i>
                        Refresh Data
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Add Modal -->
<div class="modal fade" id="quickAddModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="quick-modal-title">
                    <i class="fas fa-plus me-2"></i>
                    Add Transaction
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <form id="quickAddForm">
                    <input type="hidden" id="quick-type" name="type">
                    <input type="hidden" id="quick-category" name="category">

                    <div class="mb-3 text-center">
                        <span id="quick-category-display" class="badge bg-primary fs-6"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Amount *</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" id="quick-amount"
                                   placeholder="0.00" step="0.01" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" id="quick-description"
                               placeholder="Optional description">
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="saveQuickTransaction()">
                    <i class="fas fa-check me-2"></i>
                    Save
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/dashboard.js"></script>
}