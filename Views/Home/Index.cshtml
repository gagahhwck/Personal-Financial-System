@{
    ViewData["Title"] = "Toyota Finance - Your Money, Your Control";
}

<!-- Hero Section -->
<div class="hero-section">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <div class="container">
            <div class="row align-items-center min-vh-hero">
                <div class="col-lg-6 text-white">
                    <!-- Logo / Brand -->
                    <div class="hero-brand mb-3">
                        <span class="hero-brand-badge">
                            <i class="fas fa-car me-2"></i>TOYOTA
                        </span>
                    </div>
                    <h1 class="hero-title">Toyota Financial <br><span class="hero-accent">Services</span></h1>
                    <p class="hero-subtitle">
                        Manage your Toyota vehicle finances easily and transparently.
                        Track installments, budgets, and transactions all in one platform.
                    </p>
                    <!-- Stats Row -->
                    <div class="hero-stats mt-5">
                        <div class="hero-stat">
                            <span class="hero-stat-number">100%</span>
                            <span class="hero-stat-label">Safe & Trusted</span>
                        </div>
                        <div class="hero-stat">
                            <span class="hero-stat-number">24/7</span>
                            <span class="hero-stat-label">Always Accessible</span>
                        </div>
                        <div class="hero-stat">
                            <span class="hero-stat-number">Real-time</span>
                            <span class="hero-stat-label">Live Updates</span>
                        </div>
                    </div>
                </div>
                <!-- Right side decorative card -->
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="hero-card-preview">
                        <div class="preview-card">
                            <div class="preview-card-header">
                                <i class="fas fa-wallet me-2"></i>Total Balance
                            </div>
                            <div class="preview-card-amount">$16,500.00</div>
                            <div class="preview-card-row">
                                <span class="preview-income"><i class="fas fa-arrow-up me-1"></i>Income <strong>$5,800.00</strong></span>
                                <span class="preview-expense"><i class="fas fa-arrow-down me-1"></i>Expenses <strong>$2,150.00</strong></span>
                            </div>
                            <div class="preview-bar-wrap mt-3">
                                <div class="preview-bar" style="width:72%"></div>
                            </div>
                            <small class="text-white-50">Toyota bz4X Installment · 72% paid</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="features-section py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Key Features</h2>
            <p class="text-muted">Everything you need to manage your vehicle finances</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card text-center p-4">
                    <div class="feature-icon bg-primary-soft mb-3">
                        <i class="fas fa-chart-pie text-primary fa-2x"></i>
                    </div>
                    <h5 class="fw-bold">Financial Analytics</h5>
                    <p class="text-muted">Visualize your spending and income with interactive charts that are easy to understand.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card text-center p-4">
                    <div class="feature-icon bg-success-soft mb-3">
                        <i class="fas fa-car text-success fa-2x"></i>
                    </div>
                    <h5 class="fw-bold">Installment Management</h5>
                    <p class="text-muted">Track your Toyota vehicle installments, payment schedules, and outstanding balance in real-time.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card text-center p-4">
                    <div class="feature-icon bg-warning-soft mb-3">
                        <i class="fas fa-tags text-warning fa-2x"></i>
                    </div>
                    <h5 class="fw-bold">Transaction Categories</h5>
                    <p class="text-muted">Organize every transaction with custom categories to keep your budget structured and clear.</p>
                </div>
            </div>
        </div>
    </div>
</div>
